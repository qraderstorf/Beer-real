{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile representation",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" }
      }
    },
    "BeerLog": {
      "title": "BeerLog",
      "description": "Beer consumption log record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user": { "type": "string" },
        "beerName": { "type": "string" },
        "brewery": { "type": "string" },
        "rating": { "type": "number" },
        "date": { "type": "string" }
      }
    },
    "Pub": {
      "title": "Pub",
      "description": "Community pub group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "owner": { "type": "string" },
        "members": { "type": "array" }
      }
    },
    "PubChatMessage": {
      "title": "PubChatMessage",
      "description": "Chat message sent within a pub community",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pubId": { "type": "string" },
        "user": { "type": "string" },
        "text": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles collection"
    },
    "/beers/{beerId}": {
      "schema": { "$ref": "#/entities/BeerLog" },
      "description": "Logged beers collection"
    },
    "/pubs/{pubId}": {
      "schema": { "$ref": "#/entities/Pub" },
      "description": "Pub communities collection"
    },
    "/pub_messages/{messageId}": {
      "schema": { "$ref": "#/entities/PubChatMessage" },
      "description": "Pub community chat messages"
    }
  }
}
